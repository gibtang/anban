// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  firebaseUid String   @unique
  email       String?
  shareToken  String?  @unique
  createdAt   DateTime @default(now())
}

model Board {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  ownerId    String   @db.ObjectId
  favorited  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  columns    Column[]
  cards      Card[]

  @@index([ownerId])
}

model Agent {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  token              String    @unique
  ownerId            String?   @db.ObjectId
  approvalToken      String?
  approvalExpiresAt  DateTime?
  createdAt          DateTime  @default(now())
}

model Column {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  position  Int
  boardId   String   @db.ObjectId
  createdAt DateTime @default(now())

  board     Board    @relation(fields: [boardId], references: [id])
  cards     Card[]

  @@index([boardId])
}

model Card {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  position    Int
  columnId    String   @db.ObjectId
  boardId     String   @db.ObjectId
  tags        String[]
  agentId     String?  @db.ObjectId
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  board       Board     @relation(fields: [boardId], references: [id])
  column      Column    @relation(fields: [columnId], references: [id])

  @@index([boardId])
  @@index([columnId])
}

model AgentConfig {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  openClawId  String
  description String?
  model       String?
  enabled     Boolean  @default(true)
  ownerId     String   @db.ObjectId

  @@index([openClawId])
  @@index([ownerId])
}

model OpenClawConnection {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  gatewayUrl String
  apiKey     String?
  enabled    Boolean  @default(true)
  boardId    String   @unique @db.ObjectId
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?  @db.ObjectId
  agentId    String?  @db.ObjectId
  action     String
  entityType String
  entityId   String
  oldValues  Json?
  newValues  Json?
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([agentId])
  @@index([entityType, entityId])
  @@index([timestamp])
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  cardId    String   @db.ObjectId
  boardId   String   @db.ObjectId
  authorId  String   @db.ObjectId
  authorName String
  authorType String  @default("agent") // "agent" or "user"
  content   String
  createdAt DateTime @default(now())

  @@index([cardId])
  @@index([boardId])
}

model Activity {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  cardId     String   @db.ObjectId
  boardId    String   @db.ObjectId
  type       String   // "created", "moved", "updated", "assigned", "unassigned", "commented"
  authorId   String?  @db.ObjectId  // Agent ID or User ID
  authorName String   // Display name ("You", "Wing Zero", etc.)
  authorType String   // "agent" | "user" | "system"
  details    Json?    // { fromColumn: "To Do", toColumn: "In Progress" } or { field: "title" }
  createdAt  DateTime @default(now())

  @@index([cardId])
  @@index([boardId])
}
