# ── Core ───────────────────────────────────────────────
DATABASE_URL="mongodb+srv://..."
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ── Firebase Web Client ────────────────────────────────
# Served to the browser via GET /api/firebase-config.
# IMPORTANT: use these SERVER-ONLY names (no NEXT_PUBLIC_ prefix). They are
# resolved at RUNTIME, so updating them only requires a server restart — no
# rebuild. (The legacy NEXT_PUBLIC_* names still work as a fallback.)
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""

# ── Firebase Admin SDK (server only) ───────────────────
FIREBASE_PROJECT_ID=""          # shared with the web client block above
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ── Optional: only if you use Storage / Messaging ───────
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
# NEXT_PUBLIC_FIREBASE_APP_ID=""
